{
    "manifest_version": 3,
    "name": "VIN-sight RPO Decoder",
    "version": "1.0",
    "description": "Decodes VINs and pulls RPO codes into a side panel.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "sidePanel"
    ],
    "background": {
        "service_worker": "service-worker.js"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "action": {
        "default_title": "Click to open VIN Decoder"
    }

}